# Docker Compose 共享变量（拷贝为 .env 后生效）
# 注意：JWT_SECRET_KEY 必须为强随机字符串（建议 openssl rand -hex 32）

MYSQL_ROOT_PASSWORD=Root@2024
MYSQL_DATABASE=repair_system
MYSQL_USER=repair_user
MYSQL_PASSWORD=Repair@2024

# 必须修改！使用命令生成：openssl rand -hex 32
JWT_SECRET_KEY=please-change-me-to-a-strong-random-string-64-chars-min

CORS_ORIGINS=http://localhost,http://127.0.0.1